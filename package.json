{
  "name": "candor-ts",
  "version": "0.8.16",
  "description": "candor for TypeScript — per-function side effects, transitively, with a policy gate (candor-spec 0.8)",
  "type": "module",
  "dependencies": {
    "@types/node": "^25.9.2",
    "typescript": "^6.0.3"
  },
  "bin": {
    "candor-ts": "./scan.mjs",
    "candor-ts-query": "./query.mjs",
    "candor-ts-mcp": "./mcp.mjs",
    "candor-ts-watch": "./watch.mjs",
    "candor-mcp": "./mcp.mjs",
    "candor-lsp": "./lsp.mjs"
  },
  "scripts": {
    "lint": "eslint *.mjs",
    "test": "npm run lint && node --test test-unit.mjs && node test.mjs && node test-mcp.mjs && node test-lsp.mjs && node test-watch.mjs && npm run test:probe && npm run test:fuzz",
    "test:unit": "node --test test-unit.mjs",
    "test:probe": "node fabrication_probe.mjs",
    "test:fuzz": "node fuzz.mjs"
  },
  "license": "(MIT OR Apache-2.0)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tombaldwin/candor-ts.git"
  },
  "homepage": "https://candor.poly.io",
  "keywords": [
    "effects",
    "static-analysis",
    "side-effects",
    "call-graph",
    "policy",
    "candor"
  ],
  "engines": {
    "node": ">=20"
  },
  "files": [
    "Cases.ts",
    "scan.mjs",
    "query.mjs",
    "policy.mjs",
    "contract.mjs",
    "README.md",
    "AGENTS.md",
    "PROVE-IT.md",
    "LICENSE-MIT",
    "LICENSE-APACHE",
    "query-core.mjs",
    "scan-core.mjs",
    "mcp.mjs",
    "watch.mjs",
    "lsp.mjs"
  ],
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "globals": "^17.6.0"
  }
}
